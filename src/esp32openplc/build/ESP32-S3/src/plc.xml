    <pous>
      <pou name="main" pouType="program">
        <interface>
          <localVars>
            <variable name="BlinkTimer">
              <type>
                <derived name="TON"/>
              </type>
            </variable>
            <variable name="LED_State">
              <type>
                <BOOL/>
              </type>
              <initialValue>
                <simpleValue value="FALSE"/>
              </initialValue>
            </variable>
            <variable name="WS2812_Out" address="%QX0.0">
              <type>
                <BOOL/>
              </type>
            </variable>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml:p><![CDATA[(* 1. 1초 타이머 설정: BlinkTimer.Q가 False일 때 작동 시작, 1초 후 True 반환 *)
BlinkTimer(IN := NOT BlinkTimer.Q, PT := T#1s);

(* 2. 타이머가 완료(1초 경과)될 때마다 실행 *)
IF BlinkTimer.Q THEN
    (* 내부 상태 값을 반전 (False -> True -> False) *)
    LED_State := NOT LED_State;
END_IF;

(* 3. 실제 아두이노 13번 핀(%QX0.6)으로 신호 전송 *)
WS2812_Out := LED_State;]]></xhtml:p>
          </ST>
        </body>
